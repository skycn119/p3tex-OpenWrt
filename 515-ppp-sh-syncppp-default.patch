     [ -n "$keepalive_adaptive" ] && echo "lcp-echo-adaptive" >> /etc/ppp/options
     [ -n "$ip6table" ] && echo "ipv6-up ipv6-up $ip6table" >> /etc/ppp/options
     proto_run_command "$config" pppd "$@"
