--- a/files/ppp.sh
+++ b/files/ppp.sh
@@ -1,6 +1,7 @@
 #!/bin/sh
 . /lib/netifd/netifd-proto.sh
 
+# Default syncppp value
 proto_ppp_setup() {
     local config="$1"
     json_get_vars ip6table demand keepalive keepalive_adaptive username password pppd_options syncppp
@@ -8,6 +9,8 @@ proto_ppp_setup() {
     [ -n "$demand" ] && echo "demand $demand" >> /etc/ppp/options
     [ -n "$keepalive" ] && echo "lcp-echo-interval $keepalive" >> /etc/ppp/options
+    [ -n "$syncppp" ] || syncppp=2
